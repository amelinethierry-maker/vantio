# ============================================================
# Variables d'environnement — À copier dans Vercel
# ============================================================

# URL du site (IMPORTANT : sans slash à la fin)
NEXT_PUBLIC_SITE_URL=https://vantio.fr

# Email qui reçoit les demandes d'audit (votre boîte mail)
CONTACT_EMAIL=votre@email.fr

# Clé API Resend (récupérer sur resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 (optionnel, à activer plus tard)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Calendly (optionnel, votre lien de prise de RDV)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/votre-lien
